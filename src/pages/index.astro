---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-14 pb-10", "border-b border-border"]}>
      <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-accent/80">
        Jeremie Gros &mdash; Basel, Switzerland
      </p>
      <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
        eDiscovery PM.<br />
        <span class="text-foreground/50">Writer. Tinkerer.</span>
      </h1>
      <p class="mt-5 max-w-lg text-base leading-relaxed text-foreground/65">
        I run litigation and investigation projects — scoping matters, wrangling
        data across jurisdictions, coordinating legal teams and clients. I write
        here about work, investing, and whatever I happen to be tinkering with.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a
          href="/about"
          class="inline-flex items-center gap-1.5 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-background transition-opacity hover:opacity-90"
        >
          About me
        </a>
        <a
          href="/portfolio"
          class="inline-flex items-center gap-1.5 rounded-lg border border-border px-4 py-2 text-sm font-medium text-foreground/80 transition-colors hover:border-accent/50 hover:text-accent"
        >
          Portfolio
        </a>
      </div>
      {
        SOCIALS.length > 0 && (
          <div class="mt-6 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 text-sm text-foreground/50 whitespace-nowrap sm:mb-0">
              Find me on
            </div>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="mb-2 text-xs font-semibold uppercase tracking-widest text-foreground/40">
            Featured
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="mb-2 text-xs font-semibold uppercase tracking-widest text-foreground/40">
            Recent Posts
          </h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
