---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ...props } = data;
---

<li
  class="group my-3 rounded-xl border border-border/60 px-5 py-4 transition-all duration-200 hover:border-accent/30 hover:bg-muted/40"
>
  <a
    href={getPath(id, filePath)}
    class:list={[
      "inline-block font-semibold text-foreground",
      "transition-colors duration-150 hover:text-accent",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </Heading>
  </a>
  <Datetime {...props} />
  <p class="mt-1.5 text-sm leading-relaxed text-foreground/65">{description}</p>
</li>
